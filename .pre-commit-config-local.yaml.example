# Project-specific pre-commit hooks
# This file is OPTIONAL. If you need project-specific hooks beyond the common ones,
# copy this file to .pre-commit-config-local.yaml and customize it.
#
# Example usage:
#   cp .pre-commit-config-local.yaml.example .pre-commit-config-local.yaml
#   # Edit .pre-commit-config-local.yaml to add your hooks
#   git add .pre-commit-config-local.yaml
#   git commit -m "Add project-specific pre-commit hooks"
#
# These hooks will run AFTER the common hooks from .pre-commit-config.yaml

repos:
  - repo: local
    hooks:
      # Example: Run unit tests before commit
      - id: run-tests
        name: "Project: run unit tests"
        entry: pytest
        language: system
        pass_filenames: false
        # Uncomment to only run on Python files:
        # types: [python]

      # Example: Check for TODO comments
      # - id: check-todos
      #   name: "Project: check for TODO comments"
      #   entry: bash -c 'if grep -r "TODO" --include="*.py" .; then echo "TODO comments found!"; exit 1; fi'
      #   language: system
      #   pass_filenames: false

      # Example: Run custom linter
      # - id: custom-lint
      #   name: "Project: custom linting"
      #   entry: ./scripts/custom-lint.sh
      #   language: system
      #   types: [python]
