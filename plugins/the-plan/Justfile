default:
    @just --list

# Run the daily tending pass. Cron-callable.
tend cadence="daily":
    claude -p "Invoke the tend-the-plan skill with cadence={{cadence}}. Follow its protocol exactly." --permission-mode auto

# Show plan health summary.
status:
    claude -p "Run the /plan-status command and print its output." --permission-mode auto

# Run the weekly review pass.
review:
    just tend weekly

# Run the monthly recalibrate.
monthly:
    just tend monthly

# Run the quarterly re-anchor.
quarterly:
    just tend quarterly

# Run the annual epic review.
annual:
    just tend annual

# Walk the approval queue with the user (interactive).
approve:
    claude "Run the /plan-approve command."

# End-to-end sanity check: verify plugin structure, schema, key files exist.
smoke:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Checking plugin manifest..."
    test -f .claude-plugin/plugin.json || (echo "MISSING: plugin manifest" && exit 1)
    echo "Checking core data files..."
    test -f data/ETHICS.md || (echo "MISSING: ETHICS.md" && exit 1)
    test -f data/END_GOALS.md || (echo "MISSING: END_GOALS.md" && exit 1)
    test -f data/STATE.md || (echo "MISSING: STATE.md" && exit 1)
    test -f data/APPROVAL_QUEUE.md || (echo "MISSING: APPROVAL_QUEUE.md" && exit 1)
    echo "Checking skill..."
    test -f skills/tend-the-plan/SKILL.md || (echo "MISSING: tend-the-plan skill" && exit 1)
    echo "Checking commands..."
    test -f commands/plan-tend.md || (echo "MISSING: /plan-tend command" && exit 1)
    test -f commands/plan-status.md || (echo "MISSING: /plan-status command" && exit 1)
    test -f commands/plan-approve.md || (echo "MISSING: /plan-approve command" && exit 1)
    echo "Running Python tests..."
    python3 -m pytest tst/ -q
    echo "All smoke checks passed."

# Run Python test suite (schema validator, cron driver).
test:
    python3 -m pytest tst/ -v

# Run from a fresh state. Same as 'just tend' for now.
run: tend
