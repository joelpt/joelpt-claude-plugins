{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --project ${CLAUDE_PLUGIN_ROOT} python -m search_rag.sync --from-hook",
            "async": true
          }
        ]
      }
    ]
  }
}
